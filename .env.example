# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/court-marketplace

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Midtrans (Payment Gateway) ──────────────────────────────────────────────
# Get keys from https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Set to "true" for production environment, "false" for sandbox
MIDTRANS_IS_PRODUCTION=false

# ─── SMTP (Email Notifications) ──────────────────────────────────────────────
# Example: Gmail SMTP — enable "App Passwords" in your Google account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
